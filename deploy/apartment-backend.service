[Unit]
Description=Genesis Apartment Backend Service
After=network.target

[Service]
Type=simple
User=root
Environment=JAVA_HOME=/usr/lib/jvm/java-21-konajdk-21.0.10-1.oc9
Environment=FILE_UPLOAD_PATH=/opt/uploads
ExecStart=/usr/lib/jvm/java-21-konajdk-21.0.10-1.oc9/bin/java -jar /opt/apartment/apartment-backend/target/apartment-backend-0.0.1-SNAPSHOT.jar
WorkingDirectory=/opt/apartment/apartment-backend
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target